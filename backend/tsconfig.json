{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "ES2021",
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "dist",
        "incremental": true,
        "skipLibCheck": true
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}